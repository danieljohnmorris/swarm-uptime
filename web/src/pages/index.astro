---
const API_URL = import.meta.env.API_URL || process.env.API_URL || 'http://localhost:3001';

let monitors: any[] = [];
let error = '';

try {
  const res = await fetch(`${API_URL}/monitors`);
  if (!res.ok) throw new Error(`API returned ${res.status}`);
  monitors = await res.json();
} catch (e: any) {
  error = e.message || 'Failed to fetch monitors';
}

function statusColor(status: string) {
  if (status === 'up') return '#22c55e';
  if (status === 'down') return '#ef4444';
  return '#9ca3af';
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Status Page</title>
  </head>
  <body style="margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f9fafb; color: #111827;">
    <div style="max-width: 640px; margin: 0 auto; padding: 48px 16px;">
      <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 32px 0;">Status Page</h1>

      {error && (
        <div style="padding: 12px 16px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; color: #991b1b; margin-bottom: 24px;">
          {error}
        </div>
      )}

      {monitors.length === 0 && !error && (
        <p style="color: #6b7280;">No monitors found.</p>
      )}

      <div style="display: flex; flex-direction: column; gap: 12px;">
        {monitors.map((monitor) => (
          <a
            href={`/monitor/${monitor.id}`}
            style="display: flex; align-items: center; gap: 12px; padding: 16px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; text-decoration: none; color: inherit;"
          >
            <span
              style={`width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; background: ${statusColor(monitor.status)};`}
            />
            <div style="min-width: 0; flex: 1;">
              <div style="font-weight: 500; font-size: 15px;">{monitor.name}</div>
              <div style="font-size: 13px; color: #6b7280; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                {monitor.url}
              </div>
            </div>
            <span style={`font-size: 13px; font-weight: 500; color: ${statusColor(monitor.status)};`}>
              {monitor.status || 'unknown'}
            </span>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>
